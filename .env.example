# [scaffold] ID: T0.1 | Date: 2026-05-18 | Description: 环境变量示例（复制为 .env 并填写真实值；严禁提交真实密钥）

# ============ 运行时 ============
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# ============ 日志（V1.5）============
# LOG_TRANSPORT: auto (默认) | sync | worker
#   - auto：production → worker（异步），其它 → sync
#   - sync：强制同步直写 stdout（回滚开关）
#   - worker：强制 pino v9 worker thread 异步写入
# ⚠️ worker 模式下非受控崩溃（kill -9 / 掉电）最多丢失主线程→worker 队列中未投递的日志。
# 受控 shutdown 已 await logger.flush(timeout=2s)，覆盖正常停机路径。
# LOG_TRANSPORT=auto
# LOG_PRETTY: auto (默认) | on | off ——开发态可读输出（与 worker 互斥）
# LOG_PRETTY=auto

# ============ 存储 ============
# 支持两种协议：
#   - sqlite:<filename>  例：sqlite:./data/data.db / sqlite::memory:
#   - postgres://USER:PASS@HOST:PORT/DB  例：postgres://xs:xs@localhost:5432/xscaffold
# 可选：PG_POOL_MAX=10（仅 postgres 生效；默认 10）
DATABASE_URL=sqlite:./data/data.db

# ============ 队列 ============
# QUEUE_DRIVER: memory (默认) | bullmq
#   - memory：单进程内存队列，进程重启丢任务（适合开发与测试）
#   - bullmq：BullMQ + Redis 持久化队列（生产推荐），需同时设置 REDIS_URL
QUEUE_DRIVER=memory
REDIS_URL=redis://localhost:6379
# 可选：worker 并发上限（仅 bullmq 生效，默认 5）
# QUEUE_CONCURRENCY=5
# 可选：job 最大重试次数（仅 bullmq 生效，默认 1=不重试；工作流已有有界自愈，谨慎叠加）
# QUEUE_MAX_ATTEMPTS=1

# ============ 工作流 ============
MAX_WORKFLOW_TIMEOUT_MS=30000
TOOL_EXECUTION_TIMEOUT_MS=10000

# ============ LLM ============
# LLM_PROVIDER: stub (默认) | openai
#   - stub：不调真实 LLM，返回空响应（测试 / 无 key 时不崩）
#   - openai：调用 OpenAI / OpenAI-compatible 端点（需 OPENAI_API_KEY）
LLM_PROVIDER=stub
DEFAULT_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=
# OPENAI_BASE_URL 可指向任何 OpenAI-compatible 端点（DeepSeek / Qwen / Together / Ollama 等）
OPENAI_BASE_URL=https://api.openai.com/v1
# Agentic loop（POST /agents/:id/invoke）单次最大工具调用轮数
AGENT_MAX_ITERATIONS=8

# ============ 记忆 ============
# workflow 节点记忆窗口（条数）
MEMORY_WINDOW_SIZE=10
# 长会话（POST /agents/:id/invoke[/stream] 携 sessionId）历史窗口——二者取严：最近 N 条 且 估算 token ≤ 上限
# AGENT_HISTORY_MAX_MESSAGES=20
# AGENT_HISTORY_MAX_TOKENS=8000

# ============ 安全 ============
JWT_SECRET=replace-me-with-strong-random-string
RATE_LIMIT_PER_MINUTE=60
# METRICS_TOKEN：保护 /metrics 端点（V1.1.2 起破坏性变更）
#   - 生产环境（NODE_ENV=production）必填非空值，否则进程启动即失败
#   - 开发/测试未设时 /metrics 匿名可访问（仅打 warn）
#   - 生成：openssl rand -hex 32
#   - 拉取：Authorization: Bearer <token> 或 x-metrics-token: <token>
METRICS_TOKEN=

# 生产强烈建议保持 true（V1.1）；开发可设 false
HTTP_REQUEST_BLOCK_PRIVATE_IPS=true
# 逗号分隔；命中后跳过 IP 校验（用于受信内网服务）
HTTP_REQUEST_ALLOWED_HOSTS=

# 工作流 token 配额，单次执行（V1.1）
WORKFLOW_TOKEN_QUOTA=100000

# CORS 允许的跨源 origin 白名单（逗号分隔，全量覆盖默认）
# 默认（未设时）：http://127.0.0.1:9527, http://localhost:9527,
#                http://127.0.0.1:5173, http://localhost:5173
# 设置后会完全替换默认 —— 需要保留原默认时记得一起列出。
# 命中白名单时回显具体 origin + Allow-Credentials: true（可带 X-API-Key/JWT 跨源）。
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:9527,http://localhost:9527,http://127.0.0.1:5173,http://localhost:5173

# ============ IOOR 批量缓冲（V1.5）============
# IOOR 记录改为内存有界缓冲后批量落库，降低高并发写放大。
# 触发 flush：累计条数 / 定时 / execution 完成 / 读前查询 / 受控 shutdown。
# ⚠️ 非受控进程崩溃（kill -9 / 掉电）下最多丢失一个缓冲窗口的 IOOR 记录。
# IOOR_BATCH_SIZE=50
# IOOR_BATCH_INTERVAL_MS=1000
