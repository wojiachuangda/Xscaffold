{
  "name": "xscaffold",
  "version": "1.1.1",
  "description": "Agentic App Platform - 声明式智能应用编排平台",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "src/main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/main.js",
    "dev": "nodemon src/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "node src/infrastructure/database/migrate.js",
    "smoke:project-assistant": "node scripts/smoke/project-assistant-loop.js",
    "bench": "node scripts/perf/run-bench.js",
    "bench:server": "node scripts/perf/perf-server.js",
    "lint": "eslint src tests scripts",
    "lint:fix": "eslint src tests scripts --fix",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"scripts/**/*.js\"",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "autocannon": "^7.15.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.30.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "node scripts/check-file-header.js",
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.js": [
      "node scripts/check-file-header.js",
      "eslint --fix",
      "prettier --write"
    ],
    "scripts/**/*.js": [
      "node scripts/check-file-header.js"
    ]
  }
}
